config logban 'main'
	option enabled '1'
	option backend 'logread'
	option log_file '/var/log/auth.log'
	option firewall_backend 'auto'
	option find_time '300'
	option max_retry '5'
	option ban_time '3600'
	option cleanup_interval '30'
	option ipv4_enabled '1'
	option ipv6_enabled '1'
	option fw4_table 'fw4'
	option fw4_ban_set4 'logban4'
	option fw4_ban_set6 'logban6'
	option fw4_allow_set4 'logban4_allow'
	option fw4_allow_set6 'logban6_allow'
	option nft_family 'inet'
	option nft_table 'logban'
	option nft_chain 'input'
	option nft_set4 'blocked_ipv4'
	option nft_set6 'blocked_ipv6'
	option nft_allow_set4 'allowed_ipv4'
	option nft_allow_set6 'allowed_ipv6'

	list fail_pattern 'Bad password attempt for'
	list fail_pattern 'Failed password for'
	list fail_pattern 'Login attempt for nonexistent user'
	list fail_pattern 'Exit before auth from <'
	list fail_pattern 'luci: failed login'
	list fail_pattern 'luci: invalid password'
	list fail_pattern 'authentication failure'

	list ignore_ip '127.0.0.1'
	list ignore_ip '::1'
	list ignore_net '192.168.0.0/16'
	list ignore_net '10.0.0.0/8'
	list ignore_net '172.16.0.0/12'
	list ignore_net 'fc00::/7'
	list ignore_net 'fe80::/10'
